{
  "name": "yuzer-intelligence-engine",
  "version": "0.1.0",
  "description": "Motor de análise para dados de bar Yuzer — CAGR, correlações, Pareto, sazonalidade, previsão por regressão linear, produtos em alta. Zero dependências runtime.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./metrics/*": {
      "types": "./dist/metrics/*.d.ts",
      "import": "./dist/metrics/*.js",
      "require": "./dist/metrics/*.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "eslint src/ tests/ --fix",
    "prepublishOnly": "npm run build && npm test",
    "preversion": "npm run lint && npm run build && npm test"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "analytics",
    "insights",
    "dashboard",
    "yuzer",
    "bar-data",
    "cagr",
    "pareto",
    "correlation",
    "forecast",
    "seasonality",
    "business-intelligence"
  ],
  "author": "Tiago Hanna",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tiagohanna/yuzer-intelligence-engine.git"
  },
  "bugs": {
    "url": "https://github.com/tiagohanna/yuzer-intelligence-engine/issues"
  },
  "homepage": "https://github.com/tiagohanna/yuzer-intelligence-engine#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.39.4",
    "tsup": "^8.5.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.0.18"
  }
}
